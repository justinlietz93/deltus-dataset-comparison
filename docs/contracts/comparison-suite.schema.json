{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deltus.local/schemas/comparison-suite.schema.json",
  "title": "Deltus Comparison Suite Manifest",
  "type": "object",
  "required": ["suite_name", "baseline", "candidates", "key_columns"],
  "properties": {
    "suite_name": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
    "baseline": {"$ref": "#/$defs/csv_dataset"},
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/csv_dataset"}
    },
    "key_columns": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "excluded_columns": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "clear_nulls": {"type": "boolean", "default": true},
    "numeric_precision": {"type": ["integer", "null"], "minimum": 0},
    "max_detail_rows": {"type": "integer", "minimum": 0, "default": 10000},
    "delimiter": {"type": "string", "default": ","},
    "encoding": {"type": "string", "default": "utf-8"}
  },
  "$defs": {
    "csv_dataset": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": {"type": "string"},
        "path": {"type": "string"}
      }
    }
  }
}
